--- !u!114 &2077260017
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2077260015}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5e414ebbf2dada145878f921fc321ae2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textDisplay: {fileID: 908927937}
  backgroundImage: {fileID: 119259383}
  skipSentence: -1
  sentences:
  - "\uBD81\uBC29\uC6D0\uC815\uC5D0\uC11C \uC0B4\uC544\uB0A8\uC740 \uB2F9\uC2E0\uC740
    \uC601\uC6C5\uC73C\uB85C \uB300\uC811\uBC1B\uC558\uB2E4."
  - "\uD558\uC9C0\uB9CC, \uC9C0\uAE08\uAE4C\uC9C0 \uC190\uC5D0 \uBB3B\uD78C \uD53C\uB294
    \uB108\uBB34 \uB9CE\uC558\uACE0, \uC138\uC0C1\uC740 \uADF8\uB7F0 \uB2F9\uC2E0\uC744
    \uAC00\uB9CC\uD788 \uB450\uC9C0 \uC54A\uC558\uB2E4."
  - "\uBD81\uCABD\uC5D0\uC11C \uD65C\uB3D9\uD558\uB358 \uC218\uB9CE\uC740 \uC120\uAD50\uC0AC\uB4E4\uC774
    \uC8FD\uC74C\uC744 \uD53C\uD558\uC9C0 \uBABB\uD588\uACE0, \uADF8 \uD654\uC0B4\uC740
    \uB2F9\uC2E0\uC5D0\uAC8C\uB85C \uB3CC\uC544\uAC14\uB2E4."
  - "\uC560\uCD08\uC5D0 \uBAA8\uB4E0 \uAC74 \uB2F9\uC2E0\uC774 \uC790\uCD08\uD55C
    \uC77C\uC774\uC5C8\uC73C\uB2C8\uAE4C."
  - "\uBD81\uCABD\uC5D0\uC120 \uC5B4\uB9B0 \uC544\uC774\uB97C \uC783\uC5B4 \uC624\uC5F4\uD558\uB294
    \uBC34\uC2DC\uC758 \uC6B8\uC74C\uC18C\uB9AC\uAC00 \uBA4E\uC9C0 \uC54A\uC558\uACE0,"
  - "\uC8FD\uC740 \uC790\uB4E4\uC758 \uC6D0\uB150\uC73C\uB85C \uB9CC\uB4E4\uC5B4\uC9C4
    \uBCA0\uB974\uC138\uB974\uD06C\uAC00 \uB2F9\uC2E0\uC744 \uCC3E\uC544 \uB0A0\uB6F0\uACE0,
    \uACE0\uD5A5 \uCE5C\uAD6C\uB97C \uC783\uC740 \uADF8\uB4E4\uC740 \uBAA8\uB450
    \uB2F9\uC2E0\uACFC \uC2ED\uC790\uAC00\uB97C \uB4E4\uACE0 \uB2E4\uB2C8\uB294 \uBB38\uBA85\uC778\uB4E4\uC744
    \uC6D0\uB9DD\uD588\uB2E4."
  - "\uAD50\uD68C \uB2F9\uAD6D\uC740 \uACB0\uAD6D \uC815\uCE58\uC801 \uC555\uBC15\uACFC
    \uB300\uC678\uC801 \uC774\uBBF8\uC9C0 \uC0AC\uC774\uC5D0\uC11C \uC800\uC6B8\uD588\uACE0
    \uC774\uB0B4 \uACB0\uC815\uC744 \uB0B4\uB838\uB2E4."
  - "\uB2F9\uC2E0\uC740 \uB9CC\uCC2C\uC5D0\uC11C \uB9C8\uC9C0\uB9C9 \uD3EC\uB3C4\uC8FC\uB97C
    \uB9C8\uC2DC\uACE0, \uACE0\uD1B5\uC5D0 \uBAB8\uBD80\uB9BC\uCE58\uB2E4 \uC0B6\uC744
    \uB9C8\uAC10\uD588\uB2E4."
